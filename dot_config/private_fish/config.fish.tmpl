set fish_greeting ""

abbr -a -g ls ls -laG

if type -q eza
    abbr --add -g ls 'eza --long --classify --all --header --git --no-user --tree --level 1'
end

{{ if eq .chezmoi.os "darwin" -}}
set -l bw_socket "$HOME/Library/Containers/com.bitwarden.desktop/Data/.bitwarden-ssh-agent.sock"
if test -S $bw_socket
    set -gx SSH_AUTH_SOCK $bw_socket
end

if test -x /opt/homebrew/bin/brew
    eval (/opt/homebrew/bin/brew shellenv)
end

if test -x /usr/libexec/java_home
    set -gx JAVA_HOME (/usr/libexec/java_home -v 17)
end

test -e $HOME/.iterm2_shell_integration.fish; and source $HOME/.iterm2_shell_integration.fish

if test -f $HOME/.orbstack/shell/init2.fish
    source $HOME/.orbstack/shell/init2.fish
end
{{ end -}}

if status is-interactive
    if type -q zoxide
        zoxide init fish | source
    end

    if type -q fzf
        fzf --fish | source
    end

    # Atuin must be initialized last to properly hook history
    if type -q atuin
        atuin init fish | source
    end
end
