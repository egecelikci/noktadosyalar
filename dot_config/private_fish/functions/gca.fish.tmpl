function gca --description "Generate a precise conventional commit using Ollama"
    argparse 'm/message=' 'd/dry-run' -- $argv
    or return 1

    if not git diff --cached --quiet
        set -l changed_files (git diff --name-only --cached | string join ", ")
        set -l raw_diff (git diff --cached -U1)
        set -l recent_commits (git log -n 5 --pretty=format:"%s" 2>/dev/null)

        set -l user_hint ""
        if set -q _flag_message
            set user_hint "[USER INSTRUCTION] Prioritize this: $_flag_message"
        end

        set -l system_prompt "You are a Git auto-commit utility. Output EXACTLY ONE line. No markdown, no quotes.
Format: type(scope): description

RULES:
1. type: feat, fix, chore, docs, refactor, style, test, build, ci, perf.
2. scope: Required. Lowercase noun in parenthesis (e.g., fish, navidrome).
3. description: Max 50 chars, imperative mood (e.g., 'add', not 'added'), lowercase, no trailing period.
4. Base description ONLY on (+/-) diff lines.

EXAMPLES:
feat(lang): add polish language
fix(api): prevent racing of requests"

        set -l user_payload "[RECENT COMMITS]
$recent_commits

[FILES]
$changed_files

[DIFF]
$raw_diff

$user_hint"
        set -l max_retries 2
        set -l attempt 1
        set -l success 0
        set -l commit_msg ""

        set -l ollama_model "qwen2.5-coder:7b"

        set -l json_payload (printf '{"model": "%s", "messages": [{"role": "system", "content": %s}, {"role": "user", "content": %s}], "stream": false, "options": {"temperature": 0.1}}' \
            "$ollama_model" \
            (echo "$system_prompt" | jq -R -s '.') \
            (echo "$user_payload" | jq -R -s '.'))

        while test $attempt -le $max_retries
            if test $attempt -eq 1
                echo "Analyzing diff with $ollama_model…"
            else
                echo -e "\nRetrying (Attempt $attempt of $max_retries)…"
            end

            set -l raw_response (curl -s http://localhost:11434/api/chat -H "Content-Type: application/json" -d "$json_payload")

            set commit_msg (echo "$raw_response" | jq -r '.message.content' | string trim)
            set commit_msg (echo "$commit_msg" | sed -E '/^```/d; s/^"//; s/"$//; s/\.$//' | string lower)

            if string match -qr '^(feat|fix|chore|docs|refactor|style|test|build|ci|perf)\([a-z0-9_-]+\): .+$' "$commit_msg"
                set success 1
                break
            end

            echo -e "\n\e[1;31mValidation Failed:\e[0m \e[1;33m$commit_msg\e[0m" >&2
            set attempt (math $attempt + 1)
        end

        if test $success -eq 1
            echo -e "\nGenerated Message: \e[1;32m$commit_msg\e[0m"

            if set -q _flag_dry_run
                echo -e "\e[1;33m[DRY RUN] Commit skipped.\e[0m"
            else
                git commit -m "$commit_msg"
            end
        else
            echo "Failed to generate a valid commit message. Please commit manually." >&2
            return 1
        end
    else
        echo "No staged changes found. Use 'git add' first."
    end
end
