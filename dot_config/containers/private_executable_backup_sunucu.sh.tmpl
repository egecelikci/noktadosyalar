#!/bin/bash
set -euo pipefail
IFS=$'\n\t'
# chezmoi template: dot_config/containers/executable_backup_sunucu.sh.tmpl

{{ if eq .chezmoi.os "darwin" -}}
export RESTIC_REPOSITORY="rclone:Drive:restic"
export RESTIC_PASSWORD='{{ (bitwardenSecrets .bitwarden.restic_password_id).value }}'
export RCLONE_CONFIG_PASS='{{ (bitwardenSecrets .bitwarden.rclone_config_pass_id).value }}'
export RCLONE_CONFIG_DRIVE_CLIENT_ID='{{ (bitwardenSecrets .bitwarden.gdrive_client_id_id).value }}'
export RCLONE_CONFIG_DRIVE_CLIENT_SECRET='{{ (bitwardenSecrets .bitwarden.gdrive_client_secret_id).value }}'

echo "Stopping containers to prevent database corruption…"
docker compose -f "$HOME/.config/containers/docker-compose.yaml" stop

# Define the exact paths to back up (keeps the backup lean by avoiding caches)
BACKUP_TARGETS=(
    "$HOME/.config/deemix"
    "$HOME/.config/slskd"
    "$HOME/.config/qbittorrent"
    "$HOME/.config/prowlarr"
    "$HOME/.config/radarr"
    "$HOME/.local/share/audiomuse"
    "$HOME/.local/share/lrclib"
    "$HOME/.local/share/navidrome"
)

echo "Running Restic backup for sunucu XDG data…"
restic backup "${BACKUP_TARGETS[@]}" --host sunucu --tag media-stack

echo "Restarting containers…"
docker compose -f "$HOME/.config/containers/docker-compose.yaml" start

echo "Pruning old sunucu snapshots…"
restic forget --host sunucu --keep-daily 7 --keep-weekly 4 --keep-monthly 12 --prune
{{ else -}}
echo "This backup script is strictly for the macOS 'sunucu' environment."
{{ end -}}
