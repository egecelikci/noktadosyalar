{{ $mediaRoot := index .media_paths .chezmoi.os -}}
{{ $domain := "balcova.online" -}}

{{- $standardApps := dict
  "prowlarr" (dict "port" 9696 "tag" "latest")
  "radarr"   (dict "port" 7878 "tag" "latest")
  "sonarr"   (dict "port" 8989 "tag" "latest")
  "bazarr"   (dict "port" 6767 "tag" "latest")
  "lidarr"   (dict "port" 8686 "tag" "develop")
-}}

x-logging: &default-logging
  logging:
    driver: "json-file"
    options:
      max-size: "10m"
      max-file: "3"

x-lsi-environment: &lsi-env
  TZ: Europe/Istanbul
  PUID: "${SERVICES_UID:-1000}"
  PGID: "${MEDIA_GID:-1000}"

services:
  caddy:
    <<: *default-logging
    build:
      context: .
      dockerfile: Dockerfile.caddy
    container_name: caddy
    environment:
      CADDY_INGRESS_NETWORKS: media_network
      CLOUDFLARE_API_TOKEN: "${CLOUDFLARE_API_TOKEN}"
      CADDY_DOCKER_CADDYFILE_PATH: "/etc/caddy/Caddyfile"
    ports:
      - "80:80"
      - "443:443"
      - "443:443/udp"
    networks:
      - media_network
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - "{{ .chezmoi.homeDir }}/.local/share/caddy/data:/data"
      - "{{ .chezmoi.homeDir }}/.config/containers/Caddyfile:/etc/caddy/Caddyfile:ro"
    restart: unless-stopped
    labels:
      caddy: (tinyauth_forwarder)
      caddy.forward_auth: tinyauth:3000
      caddy.forward_auth.uri: /api/auth/caddy
      caddy.forward_auth.copy_headers: Remote-User Remote-Name Remote-Email Remote-Groups
      caddy.forward_auth.header_up: "X-Forwarded-Proto https"

  tinyauth:
    <<: *default-logging
    image: ghcr.io/tinyauthapp/tinyauth:v5
    container_name: tinyauth
    environment:
      TINYAUTH_APPURL: "https://auth.{{ $domain }}"
      TINYAUTH_OAUTH_AUTOREDIRECT: "pocketid"
      TINYAUTH_OAUTH_PROVIDERS_POCKETID_CLIENTID: "${POCKETID_CLIENT_ID}"
      TINYAUTH_OAUTH_PROVIDERS_POCKETID_CLIENTSECRET: "${POCKETID_CLIENT_SECRET}"
      TINYAUTH_OAUTH_PROVIDERS_POCKETID_AUTHURL: "https://id.{{ $domain }}/authorize"
      TINYAUTH_OAUTH_PROVIDERS_POCKETID_TOKENURL: "http://pocket-id:1411/api/oidc/token"
      TINYAUTH_OAUTH_PROVIDERS_POCKETID_USERINFOURL: "http://pocket-id:1411/api/oidc/userinfo"
      TINYAUTH_OAUTH_PROVIDERS_POCKETID_REDIRECTURL: "https://auth.{{ $domain }}/api/oauth/callback/pocketid"
      TINYAUTH_OAUTH_PROVIDERS_POCKETID_SCOPES: "openid email profile groups"
      TINYAUTH_OAUTH_PROVIDERS_POCKETID_NAME: "Pocket ID"
    networks:
      - media_network
    restart: unless-stopped
    labels:
      caddy: https://auth.{{ $domain }}
      caddy.reverse_proxy: tinyauth:3000

  pocket-id:
    <<: *default-logging
    image: pocketid/pocket-id:v2
    container_name: pocket-id
    environment:
      <<: *lsi-env
      APP_URL: "https://id.{{ $domain }}"
      ENCRYPTION_KEY: "${POCKETID_ENCRYPTION_KEY}"
      TRUST_PROXY: "true"
      TRUSTED_PLATFORM: "CF-Connecting-IP"
      SMTP_HOST: "mail.smtp2go.com"
      SMTP_PORT: "2525"
      SMTP_TLS: "starttls"
      SMTP_FROM: "auth@{{ $domain }}"
      SMTP_USER: "ege"
      SMTP_PASSWORD: "${POCKETID_SMTP_PASSWORD}"
    volumes:
      - "{{ .chezmoi.homeDir }}/.local/share/pocket-id/data:/app/data"
    networks:
      - media_network
    restart: unless-stopped
    labels:
      caddy: https://id.{{ $domain }}
      caddy.reverse_proxy: pocket-id:1411
      caddy_redir: https://{{ $domain }}
      caddy_redir.redir: https://id.{{ $domain }}{uri} permanent

  navidrome:
    <<: *default-logging
    container_name: navidrome
    image: deluan/navidrome:latest
    restart: unless-stopped
    volumes:
      - "{{ .chezmoi.homeDir }}/.local/share/navidrome/data:/data"
      - "{{ $mediaRoot }}/Music/Library:/music:ro"
    environment:
      ND_AGENTS: "audiomuseai,listenbrainz,apple-music,deezer"
      ND_ENABLEINSIGHTSCOLLECTOR: "false"
      ND_ENABLESHARING: "true"
      ND_LASTFM_APIKEY: "${LASTFM_APIKEY}"
      ND_LASTFM_SCROBBLEFIRSTARTISTONLY: "true"
      ND_LASTFM_SECRET: "${LASTFM_SECRET}"
      ND_LOGLEVEL: "info"
      ND_MUSICFOLDER: "/music"
      ND_PLUGINS_AUTORELOAD: "false"
    networks:
      - media_network
    tmpfs:
      - /data/cache:size=500m
    labels:
      caddy: https://music.{{ $domain }}
      caddy.reverse_proxy: navidrome:4533

  deemix:
    <<: *default-logging
    container_name: deemix
    build:
      context: .
      dockerfile: Dockerfile.deemix
    environment:
      DEEMIX_SINGLE_USER: "true"
    volumes:
      - "{{ .chezmoi.homeDir }}/.config/deemix:/config"
      - "{{ $mediaRoot }}/Music/Downloads/Deemix:/downloads"
    restart: unless-stopped
    networks:
      - media_network
    labels:
      caddy: https://deemix.{{ $domain }}
      caddy.reverse_proxy: deemix:6595
      caddy.import: tinyauth_forwarder

  gluetun:
    <<: *default-logging
    container_name: gluetun
    image: qmcgaw/gluetun:latest
    cap_add:
      - NET_ADMIN
    environment:
      VPN_SERVICE_PROVIDER: protonvpn
      VPN_TYPE: wireguard
      WIREGUARD_PRIVATE_KEY: "${PROTON_WG_KEY}"
      VPN_PORT_FORWARDING: "on"
      VPN_PORT_FORWARDING_PROVIDER: protonvpn
      PORT_FORWARD_ONLY: "on"
      SERVER_COUNTRIES: Turkey
      HTTP_CONTROL_SERVER_ADDRESS: ":8000"
      HTTP_CONTROL_SERVER_AUTH_DEFAULT_ROLE: '{"auth":"apikey","apikey":"${GLUETUN_API_KEY}"}'
      FIREWALL_INPUT_PORTS: "8080,5030"
    healthcheck:
      test: ["CMD", "/gluetun-entrypoint", "healthcheck"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s
    networks:
      - media_network
    restart: unless-stopped
    labels:
      caddy_0: https://qbit.{{ $domain }}
      caddy_0.reverse_proxy: gluetun:8080
      caddy_0.import: tinyauth_forwarder

      caddy_1: https://slskd.{{ $domain }}
      caddy_1.reverse_proxy: gluetun:5030
      caddy_1.import: tinyauth_forwarder

  slskd:
    <<: *default-logging
    container_name: slskd
    image: slskd/slskd:latest
    network_mode: "service:gluetun"
    environment:
      SLSKD_NO_AUTH: "true"
      SLSKD_DOWNLOADS_DIR: /downloads
      SLSKD_REMOTE_CONFIGURATION: "true"
      SLSKD_SHARED_DIR: /music
      SLSKD_SLSK_USERNAME: "${SLSK_USERNAME}"
      SLSKD_SLSK_PASSWORD: "${SLSK_PASSWORD}"
      SLSKD_VPN: "true"
      SLSKD_VPN_PORT_FORWARDING: "true"
      SLSKD_VPN_GLUETUN_URL: http://localhost:8000
      SLSKD_VPN_GLUETUN_API_KEY: "${GLUETUN_API_KEY}"
      SLSKD_API_KEY: "${SLSKD_API_KEY}"
    volumes:
      - "{{ .chezmoi.homeDir }}/.config/slskd:/app"
      - "{{ $mediaRoot }}/Music/Downloads/Soulseek:/downloads:rw"
      - "{{ $mediaRoot }}/Music/Library:/music:ro"
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- --header=\"X-Api-Key: $$SLSKD_VPN_GLUETUN_API_KEY\" http://localhost:8000/v1/vpn/status | grep -q running || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s
    restart: unless-stopped
    depends_on:
      gluetun:
        condition: service_healthy

  qbittorrent:
    <<: *default-logging
    image: lscr.io/linuxserver/qbittorrent:latest
    container_name: qbittorrent
    network_mode: "service:gluetun"
    environment:
      <<: *lsi-env
      DOCKER_MODS: ghcr.io/t-anc/gsp-qbittorent-gluetun-sync-port-mod:main
      GSP_GTN_API_KEY: "${GLUETUN_API_KEY}"
      GSP_MINIMAL_LOGS: "false"
    volumes:
      - "{{ $mediaRoot }}/torrents:/data/torrents"
      - "{{ .chezmoi.homeDir }}/.config/qbittorrent:/config"
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- --header=\"X-Api-Key: $$GSP_GTN_API_KEY\" http://localhost:8000/v1/vpn/status | grep -q running || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s
    depends_on:
      gluetun:
        condition: service_healthy

  flaresolverr:
    <<: *default-logging
    image: ghcr.io/flaresolverr/flaresolverr:latest
    container_name: flaresolverr
    environment:
      LOG_LEVEL: info
      LOG_HTML: "false"
      CAPTCHA_SOLVER: none
      TZ: Europe/Istanbul
    ports:
      - "8191:8191"
    restart: unless-stopped
    networks:
      - media_network

  audiomuse-redis:
    <<: *default-logging
    container_name: audiomuse-redis
    image: redis:7-alpine
    networks:
      - media_network

  audiomuse-postgres:
    <<: *default-logging
    container_name: audiomuse-postgres
    image: postgres:15-alpine
    environment:
      POSTGRES_USER: audiomuse
      POSTGRES_PASSWORD: "${POSTGRES_PASSWORD}"
      POSTGRES_DB: audiomusedb
    volumes:
      - "{{ .chezmoi.homeDir }}/.local/share/audiomuse/db:/var/lib/postgresql/data"
    networks:
      - media_network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U audiomuse -d audiomusedb"]
      interval: 10s
      timeout: 5s
      retries: 5
    tmpfs:
      - /dev/shm:size=256m

  audiomuse-ai-flask:
    <<: *default-logging
    image: ghcr.io/neptunehub/audiomuse-ai:latest
    container_name: audiomuse-ai-flask
    environment:
      SERVICE_TYPE: "flask"
      POSTGRES_HOST: "audiomuse-postgres"
      REDIS_URL: "redis://audiomuse-redis:6379/0"
    networks:
      - media_network
    depends_on:
      audiomuse-postgres:
        condition: service_healthy
      audiomuse-redis:
        condition: service_started

  audiomuse-ai-worker:
    <<: *default-logging
    image: ghcr.io/neptunehub/audiomuse-ai:latest
    container_name: audiomuse-ai-worker
    environment:
      SERVICE_TYPE: "worker"
      POSTGRES_HOST: "audiomuse-postgres"
      REDIS_URL: "redis://audiomuse-redis:6379/0"
    volumes:
      - "{{ $mediaRoot }}/Music/Library:/music:ro"
    networks:
      - media_network
    depends_on:
      audiomuse-postgres:
        condition: service_healthy
      audiomuse-redis:
        condition: service_started

  lrclib:
    <<: *default-logging
    container_name: lrclib
    build: https://github.com/tranxuanthang/lrclib.git#main
    ports:
      - "3300:3300"
    volumes:
      - "{{ $mediaRoot }}/lrclib/data:/data"
    environment:
      LRCLIB_LOG: info
      LRCLIB_MMAP_SIZE: 2000000000
      LRCLIB_CACHE_SIZE: -64000
    restart: unless-stopped
    networks:
      - media_network

  cloudflared:
    <<: *default-logging
    image: cloudflare/cloudflared:latest
    container_name: cloudflared
    command: tunnel run
    environment:
      TUNNEL_TOKEN: "${CLOUDFLARE_TUNNEL_TOKEN}"
    restart: unless-stopped
    networks:
      - media_network

  archivebox:
    <<: *default-logging
    profiles: ["extras"]
    container_name: archivebox
    image: archivebox/archivebox:latest
    ports:
      - "8000:8000"
    volumes:
      - "{{ .chezmoi.homeDir }}/.local/share/archivebox/data:/data"
    environment:
      ALLOWED_HOSTS: "*"
      PUBLIC_ADD_VIEW: "False"
      SAVE_ARCHIVE_DOT_ORG: "False"
      MEDIA_MAX_SIZE: 5000m
    shm_size: "1gb"
    restart: unless-stopped
    networks:
      - media_network
    labels:
      caddy: https://archive.{{ $domain }}
      caddy.reverse_proxy: archivebox:8000
      caddy.import: tinyauth_forwarder

  jellyfin:
    <<: *default-logging
    image: lscr.io/linuxserver/jellyfin:latest
    container_name: jellyfin
    environment:
      <<: *lsi-env
      UMASK: "022"
    volumes:
      - "{{ .chezmoi.homeDir }}/.config/jellyfin:/config"
      - "{{ $mediaRoot }}:/data"
    ports:
      - "8096:8096"
    restart: unless-stopped
    networks:
      - media_network
    tmpfs:
      - /tmp:size=100m,mode=1777
    labels:
      caddy: https://jellyfin.{{ $domain }}
      caddy.reverse_proxy: jellyfin:8096

  seerr:
    <<: *default-logging
    image: ghcr.io/seerr-team/seerr:latest
    init: true
    container_name: seerr
    environment:
      TZ: Europe/Istanbul
      PORT: 5055
    ports:
      - "5055:5055"
    volumes:
      - "{{ .chezmoi.homeDir }}/.config/seerr:/app/config"
    healthcheck:
      test: wget --no-verbose --tries=1 --spider http://localhost:5055/api/v1/settings/public || exit 1
      start_period: 20s
      timeout: 3s
      interval: 15s
      retries: 3
    restart: unless-stopped
    networks:
      - media_network
    labels:
      caddy: https://seerr.{{ $domain }}
      caddy.reverse_proxy: seerr:5055
      caddy.import: tinyauth_forwarder

  recyclarr:
    <<: *default-logging
    image: ghcr.io/recyclarr/recyclarr:8
    container_name: recyclarr
    user: 1000:1000
    restart: unless-stopped
    environment:
      TZ: Europe/Istanbul
      RADARR_API_KEY: "${RADARR_API_KEY}"
      SONARR_API_KEY: "${SONARR_API_KEY}"
    volumes:
      - "{{ .chezmoi.homeDir }}/.config/recyclarr:/config"
    networks:
      - media_network

  minecraft:
    <<: *default-logging
    profiles: ["extras"]
    image: itzg/minecraft-server:latest
    container_name: minecraft
    environment:
      EULA: "TRUE"
      TYPE: PAPER
      VERSION: "26.2"
      MEMORY: 2G
      TZ: Europe/Istanbul
    volumes:
      - "{{ .chezmoi.homeDir }}/.local/share/minecraft/data:/data"
    ports:
      - "25565:25565"
    restart: unless-stopped
    networks:
      - media_network
    deploy:
      resources:
        limits:
          memory: 3G

  playit:
    <<: *default-logging
    profiles: ["extras"]
    image: ghcr.io/playit-cloud/playit-agent:0.17
    container_name: playit
    network_mode: "service:minecraft"
    environment:
      SECRET_KEY: "${PLAYIT_SECRET_KEY}"
    restart: unless-stopped

  aurral:
    <<: *default-logging
    image: ghcr.io/lklynet/aurral:latest
    container_name: aurral
    environment:
      - TZ=Europe/Istanbul
      - DOWNLOAD_FOLDER=/downloads/aurral
    volumes:
      - "{{ index .media_paths .chezmoi.os }}/Music/Downloads/Aurral:/downloads/aurral"
      - "{{ .chezmoi.homeDir }}/.config/aurral/data:/app/backend/data"
    ports:
      - "3001:3001"
    restart: unless-stopped
    networks:
      - media_network
    labels:
      caddy: https://aurral.{{ $domain }}
      caddy.reverse_proxy: aurral:3001
      caddy.import: tinyauth_forwarder

  arcane:
    <<: *default-logging
    image: ghcr.io/getarcaneapp/manager:latest
    container_name: arcane
    environment:
      ENCRYPTION_KEY: "${ARCANE_ENCRYPTION_KEY}"
      JWT_SECRET: "${ARCANE_JWT_SECRET}"
      TZ: Europe/Istanbul
    volumes:
      - "/var/run/docker.sock:/var/run/docker.sock"
      - "{{ .chezmoi.homeDir }}/.local/share/arcane/data:/app/data"
    ports:
      - "3552:3552"
    cgroup: host
    restart: unless-stopped
    networks:
      - media_network
    labels:
      caddy: https://arcane.{{ $domain }}
      caddy.reverse_proxy: arcane:3552

  autoheal:
    <<: *default-logging
    image: willfarrell/autoheal:latest
    container_name: autoheal
    environment:
      AUTOHEAL_CONTAINER_LABEL: all
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
    restart: unless-stopped
    networks:
      - media_network

  {{- range $app, $config := $standardApps }}
  {{ $app }}:
    <<: *default-logging
    image: lscr.io/linuxserver/{{ $app }}:{{ if hasKey $config "tag" }}{{ $config.tag }}{{ else }}latest{{ end }}
    container_name: {{ $app }}
    environment:
      <<: *lsi-env
    volumes:
      - "{{ $.chezmoi.homeDir }}/.config/{{ $app }}:/config"
      - "{{ $mediaRoot }}:/data"
    ports:
      - "{{ $config.port }}:{{ $config.port }}"
    networks:
      - media_network
    restart: unless-stopped
    labels:
      caddy: https://{{ $app }}.{{ $domain }}
      caddy.reverse_proxy: {{ $app }}:{{ $config.port }}
      caddy.import: tinyauth_forwarder
  {{- end }}

networks:
  media_network:
    driver: bridge
    name: media_network
