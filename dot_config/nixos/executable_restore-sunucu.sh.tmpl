#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'
# chezmoi template: dot_config/nixos/executable_restore-sunucu.sh.tmpl
#
# One-time restore of the macOS 'sunucu' restic snapshot onto this box.
# Deliberately NOT run_once_: this stops real services and overwrites
# real data directories, so it only runs when invoked by hand, after
# `nixos-rebuild switch` has already created the service users/groups
# and empty state dirs, and before those services have written anything
# new of their own.

{{ if eq .chezmoi.os "linux" -}}
export RESTIC_REPOSITORY="rclone:Drive:restic"
export RESTIC_PASSWORD='{{ (bitwardenSecrets .bitwarden.restic_password_id).value }}'
export RCLONE_CONFIG_PASS='{{ (bitwardenSecrets .bitwarden.rclone_config_pass_id).value }}'
export RCLONE_CONFIG_DRIVE_CLIENT_ID='{{ (bitwardenSecrets .bitwarden.gdrive_client_id_id).value }}'
export RCLONE_CONFIG_DRIVE_CLIENT_SECRET='{{ (bitwardenSecrets .bitwarden.gdrive_client_secret_id).value }}'

SNAPSHOT_HOST="sunucu"
# The snapshot was taken on macOS — its stored paths are /Users/egecelikci/...,
# not /home/egecelikci/... Confirm with: restic snapshots --host sunucu -l
MAC_HOME="Users/egecelikci"     # relative, no leading slash (restic strips it under --target)
NIXOS_HOME="/home/egecelikci"
SCRATCH="$(mktemp -d /tmp/restic-restore.XXXXXX)"
trap 'rm -rf "$SCRATCH"' EXIT

# Apps that moved to native NixOS modules (native-services.nix). Docker on
# macOS bind-mounted these flat under ~/.config/<app> (linuxserver-style
# /config layout); the native .NET arr apps want that content one level
# deeper, under /var/lib/<svc>/.config/<PascalCaseName>. bazarr/prowlarr/
# jellyfin/seerr/qbittorrent/navidrome stay flat at /var/lib/<svc>.
#
# VERIFY before running: bazarr has no dataDir option upstream (check
# `systemctl cat bazarr` on this box for the real path), and confirm
# "seerr" is actually your module's state-dir name.
declare -A NATIVE_MAP=(
  [radarr]="$MAC_HOME/.config/radarr|/var/lib/radarr/.config/Radarr"
  [sonarr]="$MAC_HOME/.config/sonarr|/var/lib/sonarr/.config/Sonarr"
  [lidarr]="$MAC_HOME/.config/lidarr|/var/lib/lidarr/.config/Lidarr"
  [bazarr]="$MAC_HOME/.config/bazarr|/var/lib/bazarr"
  [prowlarr]="$MAC_HOME/.config/prowlarr|/var/lib/prowlarr"
  [jellyfin]="$MAC_HOME/.config/jellyfin|/var/lib/jellyfin"
  [seerr]="$MAC_HOME/.config/seerr|/var/lib/seerr"
  [qbittorrent]="$MAC_HOME/.config/qbittorrent|/var/lib/qbittorrent"
  [navidrome]="$MAC_HOME/.local/share/navidrome|/var/lib/navidrome"
)

# Still on virtualisation.oci-containers (containers.nix), same relative
# layout as macOS — just under a different home dir, so still remapped.
declare -A DOCKER_MAP=(
  [deemix]="$MAC_HOME/.config/deemix|$NIXOS_HOME/.config/deemix"
  [slskd]="$MAC_HOME/.config/slskd|$NIXOS_HOME/.config/slskd"
  [recyclarr]="$MAC_HOME/.config/recyclarr|$NIXOS_HOME/.config/recyclarr"
  [aurral]="$MAC_HOME/.config/aurral|$NIXOS_HOME/.config/aurral"
  [pocket-id]="$MAC_HOME/.local/share/pocket-id|$NIXOS_HOME/.local/share/pocket-id"
  [archivebox]="$MAC_HOME/.local/share/archivebox|$NIXOS_HOME/.local/share/archivebox"
  [arcane]="$MAC_HOME/.local/share/arcane|$NIXOS_HOME/.local/share/arcane"
)

restore_map() {
  local -n map_ref=$1
  local include_args=()
  for app in "${!map_ref[@]}"; do
    include_args+=(--include "/${map_ref[$app]%%|*}")
  done
  restic restore latest --host "$SNAPSHOT_HOST" --target "$SCRATCH" "${include_args[@]}"
}

echo "Stopping native services…"
sudo systemctl stop "${!NATIVE_MAP[@]}" || true

echo "Restoring native-service paths into $SCRATCH…"
restore_map NATIVE_MAP
for app in "${!NATIVE_MAP[@]}"; do
  src="$SCRATCH/${NATIVE_MAP[$app]%%|*}"
  dst="${NATIVE_MAP[$app]##*|}"
  if [ -d "$src" ]; then
    echo "  $app -> $dst"
    sudo mkdir -p "$dst"
    sudo rsync -a "$src"/ "$dst"/
    sudo chown -R media:media "$dst"
  else
    echo "SKIP: $APP not present in snapshot (expected if backup predates migration)"
  fi
done

echo "Restarting native services…"
sudo systemctl start "${!NATIVE_MAP[@]}"

echo "Restoring Docker appdata into $SCRATCH…"
restore_map DOCKER_MAP
for app in "${!DOCKER_MAP[@]}"; do
  src="$SCRATCH/${DOCKER_MAP[$app]%%|*}"
  dst="${DOCKER_MAP[$app]##*|}"
  if [ -d "$src" ]; then
    echo "  $app -> $dst"
    mkdir -p "$dst"
    rsync -a "$src"/ "$dst"/
  else
    echo "SKIP: $APP not present in snapshot (expected if backup predates migration)"
  fi
done
sudo chown -R "egecelikci:$(id -gn egecelikci)" "$NIXOS_HOME/.config" "$NIXOS_HOME/.local/share"

echo "Done. Diff the restored configs against native-services.nix/containers.nix before trusting them."
{{ else -}}
echo "This restore script is strictly for the NixOS 'sunucu' migration target."
{{ end -}}
