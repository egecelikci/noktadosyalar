#!/usr/bin/env fish

{{ if eq .chezmoi.os "linux" -}}
set SERVICES_USER "services"
set SERVICES_HOME "/home/$SERVICES_USER"
set SERVICES_SYSTEMD_DIR "$SERVICES_HOME/.config/containers/systemd"

if not id -u $SERVICES_USER >/dev/null 2>&1
    echo "Creating dedicated '$SERVICES_USER' user…"
    sudo useradd -m $SERVICES_USER
    sudo loginctl enable-linger $SERVICES_USER
end

# 1. PROVISION DIRECTORIES FIRST
set MEDIA_GROUP "mediashare"

if not getent group $MEDIA_GROUP >/dev/null
    echo "Creating '$MEDIA_GROUP' group…"
    sudo groupadd $MEDIA_GROUP
end

sudo usermod -aG $MEDIA_GROUP $SERVICES_USER
sudo usermod -aG $MEDIA_GROUP $USER

set ROOT_STORAGE "/mnt/unified"
set MEDIA_DIR "$ROOT_STORAGE/media"
set DOWNLOADS_DIR "$ROOT_STORAGE/downloads"

echo "Provisioning unified directory structure at $ROOT_STORAGE…"
sudo mkdir -p "$MEDIA_DIR/Music" "$MEDIA_DIR/TV" "$MEDIA_DIR/Movies"
sudo mkdir -p "$DOWNLOADS_DIR/deemix" "$DOWNLOADS_DIR/slskd" "$DOWNLOADS_DIR/torrents"
sudo chown -R $SERVICES_USER:$MEDIA_GROUP "$MEDIA_DIR" "$DOWNLOADS_DIR"
sudo chmod -R 2775 "$MEDIA_DIR" "$DOWNLOADS_DIR"

echo "Deploying Quadlets to '$SERVICES_USER'…"

sudo -u $SERVICES_USER mkdir -p $SERVICES_SYSTEMD_DIR

set RENDERED_NAVIDROME "$HOME/.config/containers/systemd/navidrome.container"

if test -f "$RENDERED_NAVIDROME"
    sudo cp "$RENDERED_NAVIDROME" "$SERVICES_SYSTEMD_DIR/"
    sudo chown $SERVICES_USER:$SERVICES_USER "$SERVICES_SYSTEMD_DIR/navidrome.container"
    sudo chmod 644 "$SERVICES_SYSTEMD_DIR/navidrome.container"

    set SERVICE_UID (id -u $SERVICES_USER)
    set -x XDG_RUNTIME_DIR "/run/user/$SERVICE_UID"
    set -x DBUS_SESSION_BUS_ADDRESS "unix:path=$XDG_RUNTIME_DIR/bus"

    echo "Reloading systemd daemon for $SERVICES_USER…"
    sudo -u $SERVICES_USER env XDG_RUNTIME_DIR=$XDG_RUNTIME_DIR DBUS_SESSION_BUS_ADDRESS=$DBUS_SESSION_BUS_ADDRESS systemctl --user daemon-reload

    echo "Enabling and starting Navidrome…"
    sudo -u $SERVICES_USER env XDG_RUNTIME_DIR=$XDG_RUNTIME_DIR DBUS_SESSION_BUS_ADDRESS=$DBUS_SESSION_BUS_ADDRESS systemctl --user enable --now navidrome.service

    echo "Deployment complete! Navidrome should be running on port 4533."
else
    echo "Error: Rendered Navidrome container file not found at $RENDERED_NAVIDROME." >&2
end
{{ end -}}
